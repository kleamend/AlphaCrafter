# =============================================================================
# LLM Provider Credentials
# =============================================================================
# AlphaCrafter 通过 OpenAI Python SDK 兼容的 Chat Completions 端点对接 LLM。
# 你只需要填两个变量：API 服务的 base URL 与 API Key。
#
# 当前默认接入 MiniMax-M3（原 MiniMax 系列；1M 上下文、原生 tool calling）。
# 如需切换至其它 OpenAI 兼容端点，只需修改 API_URL 和 API_KEY，
# 并在 sandbox/<session>/config/models.json 中添加对应模型条目。

# ----- MiniMax-M3（默认）-----
API_URL=https://api.minimaxi.com/v1
API_KEY=YOUR_MINIMAX_API_KEY_HERE
